{
  "name": "@alesha-nov/auth",
  "version": "0.2.5",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    },
    "./utils": {
      "types": "./dist/utils.d.ts",
      "import": "./dist/utils.js"
    },
    "./migrations": {
      "types": "./dist/migrations.d.ts",
      "import": "./dist/migrations.js"
    },
    "./user-store": {
      "types": "./dist/user-store.d.ts",
      "import": "./dist/user-store.js"
    },
    "./service": {
      "types": "./dist/service.d.ts",
      "import": "./dist/service.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/types.ts src/utils.ts src/migrations.ts src/user-store.ts src/service.ts --format esm --dts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "bun test"
  },
  "dependencies": {
    "@alesha-nov/db": "workspace:*",
    "@alesha-nov/email": "workspace:*"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/JuniYadi/alesha-nov.git",
    "directory": "packages/auth"
  },
  "license": "MIT",
  "author": "JuniYadi",
  "keywords": [
    "alesha",
    "auth",
    "authentication",
    "authorization",
    "bun",
    "oauth",
    "magic-link"
  ],
  "homepage": "https://github.com/JuniYadi/alesha-nov#readme",
  "bugs": {
    "url": "https://github.com/JuniYadi/alesha-nov/issues"
  },
  "engines": {
    "node": ">=22.12.0",
    "bun": ">=1.3.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
