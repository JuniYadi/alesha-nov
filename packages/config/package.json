{
  "name": "@alesha-nov/config",
  "version": "0.2.1",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./auth-migrations": {
      "types": "./dist/auth-migrations.d.ts",
      "import": "./dist/auth-migrations.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/auth-migrations.ts --format esm --dts --external bun",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "bun test"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/JuniYadi/alesha-nov.git",
    "directory": "packages/config"
  },
  "license": "MIT",
  "author": "JuniYadi",
  "keywords": [
    "alesha",
    "config",
    "bun",
    "database",
    "sql",
    "migrations"
  ],
  "homepage": "https://github.com/JuniYadi/alesha-nov#readme",
  "bugs": {
    "url": "https://github.com/JuniYadi/alesha-nov/issues"
  },
  "engines": {
    "node": ">=22.12.0",
    "bun": ">=1.3.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
