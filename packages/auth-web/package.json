{
  "name": "@alesha-nov/auth-web",
  "version": "0.2.1",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./next": {
      "types": "./dist/next.d.ts",
      "import": "./dist/next.js"
    },
    "./tanstack": {
      "types": "./dist/tanstack.d.ts",
      "import": "./dist/tanstack.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/next.ts src/tanstack.ts --format esm --dts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "bun test"
  },
  "dependencies": {
    "@alesha-nov/auth": "workspace:*"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/JuniYadi/alesha-nov.git",
    "directory": "packages/auth-web"
  },
  "license": "MIT",
  "author": "JuniYadi",
  "keywords": [
    "alesha",
    "auth",
    "web",
    "nextjs",
    "tanstack",
    "routes",
    "middleware"
  ],
  "homepage": "https://github.com/JuniYadi/alesha-nov#readme",
  "bugs": {
    "url": "https://github.com/JuniYadi/alesha-nov/issues"
  },
  "engines": {
    "node": ">=22.12.0",
    "bun": ">=1.3.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
