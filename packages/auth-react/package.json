{
  "name": "@alesha-nov/auth-react",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./context": {
      "types": "./src/context.tsx",
      "default": "./src/context.tsx"
    },
    "./hooks": {
      "types": "./src/hooks.ts",
      "default": "./src/hooks.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/context.tsx src/hooks.ts --format esm --dts --clean",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "bun test --preload ./src/test-setup.ts"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^29.0.2",
    "react": "^19.0.0",
    "react-dom": "^19.2.4"
  }
}
