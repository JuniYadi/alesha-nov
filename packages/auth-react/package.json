{
  "name": "@alesha-nov/auth-react",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./context": {
      "types": "./dist/context.d.ts",
      "import": "./dist/context.js"
    },
    "./hooks": {
      "types": "./dist/hooks.d.ts",
      "import": "./dist/hooks.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/context.tsx src/hooks.ts --format esm --dts --clean",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "bun test --preload ./src/test-setup.ts --max-concurrency 1"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^29.0.2",
    "react": "^19.0.0",
    "react-dom": "^19.2.4"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/JuniYadi/alesha-nov.git",
    "directory": "packages/auth-react"
  },
  "license": "MIT",
  "author": "JuniYadi",
  "keywords": [
    "alesha",
    "auth",
    "react",
    "hooks",
    "context",
    "auth-guard"
  ],
  "homepage": "https://github.com/JuniYadi/alesha-nov#readme",
  "bugs": {
    "url": "https://github.com/JuniYadi/alesha-nov/issues"
  },
  "engines": {
    "node": ">=22.12.0",
    "bun": ">=1.3.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
